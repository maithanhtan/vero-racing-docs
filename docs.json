{
  "$schema": "https://mintlify.com/docs.json",
  "theme": "maple",
  "name": "Vero Racing Docs",
  "seo": {
    "indexing": "all",
    "metatags": {
      "description": "Hướng dẫn sử dụng hệ thống Vero Racing — thiết lập, triển khai và vận hành các dịch vụ gửi lệnh tốc độ cao.",
      "og:title": "Vero Racing Docs",
      "og:description": "Tài liệu hướng dẫn triển khai và vận hành Vero Racing",
      "og:site_name": "Vero Racing Docs"
    }
  },
  "colors": {
    "primary": "#16a34a",
    "light": "#4ade80",
    "dark": "#15803d"
  },
  "appearance": {
    "default": "light",
    "strict": false
  },
  "fonts": {
    "heading": {
      "family": "Be Vietnam Pro"
    },
    "body": {
      "family": "Noto Sans"
    }
  },
  "icons": {
    "library": "fontawesome"
  },
  "background": {
    "decoration": "grid"
  },
  "favicon": "/favicon.png",
  "css": "/custom.css",
  "navigation": {
    "style": "minimal",
    "groups": [
      {
        "group": "Home",
        "pages": [
          "index"
        ]
      },
      {
        "group": "Bắt đầu",
        "pages": [
          "quickstart",
          "development"
        ]
      },
      {
        "group": "Hướng dẫn nâng cao",
        "pages": [
          "vrf-guide",
          "vrb-guide",
          "vor-guide"
        ]
      },
      {
        "group": "Hỗ trợ",
        "pages": [
          "lien-he"
        ]
      }
    ],
    "global": {}
  },
  "sidebar": {
    "items": "border"
  },
  "logo": {
    "light": "/logo/vero-logo.png",
    "dark": "/logo/vero-logo.png"
  },
  "navbar": {
    "links": [],
    "primary": {
      "type": "button",
      "label": "Dashboard",
      "href": "https://racing.verolabs.co"
    }
  },
  "footer": {
    "socials": {
      "website": "https://verolabs.co"
    }
  }
}
